# API base URL for scripts/tests (defaults to http://127.0.0.1:8000)
BASE=http://127.0.0.1:8000

# Runtime config
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=INFO
# LOG_JSON=true
#
# Data + model paths
# DATA_PATH=data/raw/cre_deals.csv
# DATASET_METADATA_PATH=data/metadata/dataset_metadata.json
# MODEL_PATH=models/model.joblib
# MODEL_SNAPSHOT_PATH=reports/model_snapshot.json
# REPORTS_DIR=reports
# EXPLAINABILITY_JSON_PATH=reports/feature_importance.json
#
# Validation
# TS_CV_SPLITS=8
#
# Auth (optional)
# AUTH_MODE=none
# AUTH_TOKEN=replace-me
